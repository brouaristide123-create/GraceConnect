generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Super Admin ──────────────────────────────────────────────────────────────
model SuperAdmin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Church (Église) ──────────────────────────────────────────────────────────
model Church {
  id              Int      @id @default(autoincrement())
  name            String
  denomination    String?  // Ex: Protestante, Catholique, Évangélique...
  address         String?
  city            String?
  country         String   @default("Côte d'Ivoire")
  phone           String?
  email           String?
  ownerEmail      String   @unique
  passwordHash    String
  logoUrl         String?
  currency        String   @default("FCFA")
  status          String   @default("active") // active | suspended
  mustChangePassword Boolean @default(true)
  settings        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members         Member[]
  families        Family[]
  departments     Department[]
  employees       Employee[]
  events          ChurchEvent[]
  contributions   Contribution[]
  expenses        Expense[]
  announcements   Announcement[]
  groups          Group[]
}

// ─── Employee (Staff de l'église) ─────────────────────────────────────────────
model Employee {
  id               Int      @id @default(autoincrement())
  churchId         Int
  church           Church   @relation(fields: [churchId], references: [id])
  firstName        String
  lastName         String
  identifier       String
  role             String   @default("staff") // pastor | secretary | treasurer | staff
  email            String?
  phone            String?
  passwordHash     String
  status           String   @default("active") // active | disabled
  mustChangePassword Boolean @default(true)
  permissions      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([churchId, identifier])
}

// ─── Member (Membre de l'église) ──────────────────────────────────────────────
model Member {
  id              Int      @id @default(autoincrement())
  churchId        Int
  church          Church   @relation(fields: [churchId], references: [id])
  memberId        String?  // Numéro de membre
  firstName       String
  lastName        String
  gender          String?  // M | F
  birthDate       DateTime?
  phone           String?
  email           String?
  address         String?
  photoUrl        String?
  status          String   @default("active") // active | inactive | visitor
  maritalStatus   String?  // single | married | widowed | divorced
  baptized        Boolean  @default(false)
  baptismDate     DateTime?
  joinDate        DateTime @default(now())
  familyId        Int?
  family          Family?  @relation(fields: [familyId], references: [id])
  departmentId    Int?
  department      Department? @relation(fields: [departmentId], references: [id])
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendances     Attendance[]
  contributions   Contribution[]
}

// ─── Family (Famille) ─────────────────────────────────────────────────────────
model Family {
  id        Int      @id @default(autoincrement())
  churchId  Int
  church    Church   @relation(fields: [churchId], references: [id])
  name      String   // Ex: "Famille Koné"
  headName  String?  // Chef de famille
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]
}

// ─── Department / Ministère ───────────────────────────────────────────────────
model Department {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  name        String   // Ex: Chorale, Jeunesse, Femmes, Hommes, Enfants...
  description String?
  leaderId    Int?     // ID du membre responsable
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     Member[]
}

// ─── Group (Cellule / groupe de maison) ───────────────────────────────────────
model Group {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  name        String
  type        String   @default("cell") // cell | house_group | prayer
  leaderId    Int?
  meetingDay  String?
  meetingTime String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Event (Événement) ────────────────────────────────────────────────────────
model ChurchEvent {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  title       String
  description String?
  type        String   @default("service") // service | meeting | special | revival | training
  startDate   DateTime
  endDate     DateTime?
  location    String?
  isRecurring Boolean  @default(false)
  recurrence  String?  // weekly | biweekly | monthly
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances Attendance[]
}

// ─── Attendance (Présence) ────────────────────────────────────────────────────
model Attendance {
  id        Int      @id @default(autoincrement())
  eventId   Int
  event     ChurchEvent @relation(fields: [eventId], references: [id])
  memberId  Int?
  member    Member?  @relation(fields: [memberId], references: [id])
  visitorName String?  // Pour les visiteurs non membres
  status    String   @default("present") // present | absent | excused
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

// ─── Contribution (Offrande / Dîme / Don) ─────────────────────────────────────
model Contribution {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  memberId    Int?
  member      Member?  @relation(fields: [memberId], references: [id])
  type        String   @default("offering") // offering | tithe | special | building_fund
  amount      Float
  method      String   @default("cash") // cash | mobile_money | bank | check
  reference   String?  // Référence paiement
  description String?
  date        DateTime @default(now())
  receivedBy  String?  // Nom du trésorier
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Expense (Dépense de l'église) ────────────────────────────────────────────
model Expense {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  description String
  amount      Float
  category    String   @default("other") // utilities | salary | maintenance | outreach | equipment | other
  method      String   @default("cash")
  date        DateTime @default(now())
  approvedBy  String?
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Announcement (Annonce / Communication) ───────────────────────────────────
model Announcement {
  id          Int      @id @default(autoincrement())
  churchId    Int
  church      Church   @relation(fields: [churchId], references: [id])
  title       String
  content     String
  type        String   @default("general") // general | urgent | event | prayer
  targetGroup String?  // all | youth | women | men | etc.
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Password Reset ───────────────────────────────────────────────────────────
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  userType  String   // church | superadmin
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
